  "risks": [
    {
      "id": "R1",
      "title": "CI/CD timeout issues",
      "mitigation": "Parallel job execution, test filtering by affected files"
    },
    {
      "id": "R2",
      "title": "Flaky test failures",
      "mitigation": "Fixed random seeds, async patterns, retry logic in tests"
    },
    {
      "id": "R3",
      "title": "Frontend framework compatibility",
      "mitigation": "Use stable versions, test in CI early, fallback patterns documented"
    },
    {
      "id": "R4",
      "title": "Coverage regression",
      "mitigation": "Gating prevents merge if coverage decreases, trend alerts"
    }
  ],
